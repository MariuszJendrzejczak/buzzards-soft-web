# Production feature flags. Values are NEXT_PUBLIC_* — public by definition,
# safe to commit. Closed-by-default policy per ADR 0001 — flip to "true" only
# when the referenced project is ready to be shown publicly.

# HomeStorage mobile MVP is ready to show in the agent-portfolio tile.
NEXT_PUBLIC_HOME_STORAGE_MVP_LIVE=true

# Polilocale OSS repo is public-facing.
NEXT_PUBLIC_POLILOCALE_REPO_PUBLIC=true
